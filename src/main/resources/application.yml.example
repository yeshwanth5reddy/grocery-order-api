server:
  port: 9090

spring:
  application:
    name: grocery-order-api

  datasource:
    url: jdbc:postgresql://YOUR_NEON_HOST/YOUR_DB?sslmode=require
    username: YOUR_USERNAME
    password: YOUR_PASSWORD
    driver-class-name: org.postgresql.Driver

  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    open-in-view: false
    properties:
      hibernate:
        format_sql: true


management:
  endpoints:
    web:
      exposure:
        include: health,info

jwt:
  secret: YOUR_BASE64_SECRET_KEY_AT_LEAST_256_BITS
  expiration: 86400000

springdoc:
  swagger-ui:
    path: /swagger-ui.html
  api-docs:
    path: /api-docs